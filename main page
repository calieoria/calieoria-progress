<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Progress</title>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background: #0a0a0a;
    color: #eaeaea;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .container {
    text-align: center;
    width: 300px;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 30px;
    opacity: 0.8;
  }

  .progress-bar {
    width: 100%;
    height: 6px;
    background: #1f1f1f;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 10px;
  }

  .progress {
    height: 100%;
    width: 42%; /* change this number */
    background: #ffffff;
    transition: width 0.6s ease;
  }

  .percent {
    font-size: 0.9rem;
    opacity: 0.5;
  }

  .footer {
    margin-top: 40px;
    font-size: 0.75rem;
    opacity: 0.3;
  }
</style>
</head>

<body>

<div class="container">
  <h1>work in progress</h1>

  <div class="progress-bar">
    <div class="progress"></div>
  </div>

  <div class="percent">42%</div>

  <div class="footer">coming soon</div>
</div>

</body>
</html>
